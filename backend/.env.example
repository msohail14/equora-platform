PORT=6060

DB_HOST=localhost
DB_PORT=3306
DB_NAME=horse_riding
DB_USER=root
DB_PASSWORD=your_secure_db_password_here
DB_DIALECT=mysql

JWT_SECRET=replace_with_64_char_random_string
JWT_EXPIRES_IN=7d
RESET_TOKEN_EXPIRES_MINUTES=15
EMAIL_OTP_EXPIRES_MINUTES=10

# SSL certificates (self-hosted VPS only, not needed on Railway/Render/etc.)
USE_HTTPS=false
SSL_CERT_PATH=/etc/letsencrypt/live/yourdomain.com/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/yourdomain.com/privkey.pem

NODE_ENV=development

FRONTEND_URL_DEV=http://localhost:5173
FRONTEND_URL_PROD=https://yourdomain.com

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS="your_smtp_app_password"
MAIL_FROM="Equestrian App <your_email@gmail.com>"

# Admin invite secret (required for admin signup)
ADMIN_INVITE_SECRET=replace_with_strong_invite_secret

# Google Places API (for stable address autocomplete in admin dashboard)
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Firebase Auth (phone OTP verification)
FIREBASE_PROJECT_ID=equorariding
# Either provide a base64-encoded service account JSON:
# FIREBASE_SERVICE_ACCOUNT_JSON=base64_encoded_json_here
# Or a path to the service account key file:
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# OTP Bypass (for dev/testing when Firebase billing is pending)
# Set to 'true' to accept OTP code '123456' for any phone number
FIREBASE_OTP_BYPASS=true

# Magic Link
MAGIC_LINK_EXPIRES_MINUTES=15

# Invitations
INVITATION_EXPIRES_DAYS=7
